# Anthropic (Claude) API key — required for video analysis
ANTHROPIC_API_KEY=sk-ant-...

# Notion API integration token — required for page creation
NOTION_API_KEY=ntn_...

# Notion database ID where analysis pages will be created
NOTION_DATABASE_ID=31929321-fe1b-814c-a535-e29d3e7778dd

# Allowed CORS origins (JSON array of strings)
CORS_ORIGINS=["http://localhost:3000"]

# Local storage directories (relative to where uvicorn runs)
UPLOAD_DIR=./uploads
DOWNLOAD_DIR=./downloads

# Claude model to use for video analysis
CLAUDE_MODEL=claude-opus-4-5

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=100

# Firebase — path to service account key JSON file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase project ID
FIREBASE_PROJECT_ID=mmo-dashboard-89780
