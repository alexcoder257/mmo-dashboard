{
  "name": "mmo-dashboard",
  "description": "MMO Dashboard application",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">= 22",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "bun": "please-use-pnpm"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "corepack enable && corepack prepare pnpm@10.12.3 --activate && next build && pnpm dlx @cloudflare/next-on-pages@1",
    "preview:cloudflare": "pnpm dlx wrangler pages dev .vercel/output/static --compatibility-date=2025-01-06 --compatibility-flag=nodejs_compat",
    "deploy:cloudflare": "pnpm dlx @cloudflare/next-on-pages@1 && pnpm dlx wrangler pages deploy .vercel/output/static --project-name=mmo-dashboard",
    "start": "next start",
    "format": "prettier . --write",
    "lint": "eslint . --fix",
    "type-check": "tsc --build --force",
    "check-all": "run-p format lint type-check",
    "preinstall": "pnpm dlx only-allow pnpm",
    "prepare": "husky",
    "precommit": "lint-staged && validate-branch-name"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm run format",
      "pnpm run lint",
      "git add ."
    ]
  },
  "validate-branch-name": {
    "pattern": "^(feature|bugfix|hotfix|release)/.+$"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.0.2",
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-query": "^5.75.2",
    "antd": "^5.23.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "deepmerge": "^4.3.1",
    "html-react-parser": "^5.2.6",
    "html2canvas": "^1.4.1",
    "js-cookie": "^3.0.5",
    "jspdf": "^3.0.2",
    "next": "^15.3.0",
    "next-intl": "^4.0.2",
    "nextjs-toploader": "^3.8.16",
    "qs": "^6.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-hook-form-antd": "^1.1.3",
    "sharp": "^0.34.2",
    "string-template": "^1.0.0",
    "swiper": "^11.2.7",
    "usehooks-ts": "^3.1.1",
    "uuid": "^11.0.3",
    "yup": "^1.6.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.12",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "@svgr/webpack": "^8.1.0",
    "@types/html2canvas": "^1.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/qs": "^6.9.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/string-template": "^1.0.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.3.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-perfectionist": "^4.6.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "sass": "1.77.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "typescript-eslint": "^8.20.0",
    "validate-branch-name": "^1.3.1",
    "vercel": "^42.3.0",
    "webpack": "^5.99.5",
    "wrangler": "^4.19.1"
  },
  "packageManager": "pnpm@10.12.3+sha512.467df2c586056165580ad6dfb54ceaad94c5a30f80893ebdec5a44c5aa73c205ae4a5bb9d5ed6bb84ea7c249ece786642bbb49d06a307df218d03da41c317417"
}
